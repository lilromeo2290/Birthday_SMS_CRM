# Database (SQLite path — change for production if using PostgreSQL)
DATABASE_URL=file:./db/custom.db

# JWT Secret (generate a long random string for production!)
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# App URL (your domain)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Port (default 3000)
PORT=3000